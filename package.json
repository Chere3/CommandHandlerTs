{
  "name": "bottemplate",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "engines": {
    "node": ">=14.x"
  },
  "scripts": {
    "start": "npx ts-node src/index.ts",
    "dev": "nodemon src/index.ts --exec \"ts-node src/index.ts\" -e ts,json",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run build",
    "test": "npm run typecheck"
  },
  "keywords": [
    "bot-template",
    "discord.js-bot",
    "botTemplate"
  ],
  "author": "Diego",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chere3/CommandHandlerTs.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "captainjs": "^1.0.4",
    "discord.js": "^13.1.0",
    "dotenv": "^10.0.0",
    "mongoose": "^5.13.2",
    "mpath": "^0.8.4",
    "node-superfetch": "^0.2.3",
    "nodemon": "^2.0.12",
    "superagent": "^6.1.0",
    "typescript": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^16.3.2",
    "ts-node": "^10.1.0"
  }
}
